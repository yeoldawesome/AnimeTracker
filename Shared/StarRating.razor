@using Microsoft.AspNetCore.Components
<div class="star-rating" aria-label="@Label">
    @for (var i = 1; i <= 5; i++)
    {
        var fill = GetStarFill(i);
        <button type="button" class="star-button" @onclick="() => SetRating(i)" aria-label="@($"{i} star{(i == 1 ? string.Empty : "s")}")">
            <span class="star-shape" style="--fill:@fill%">★</span>
        </button>
    }
</div>

@code {
    [Parameter] public double Value { get; set; }
    [Parameter] public EventCallback<double> ValueChanged { get; set; }
    [Parameter] public string Label { get; set; } = "Rating";

    private int GetStarFill(int star)
    {
        if (Value >= star)
        {
            return 100;
        }

        if (Value <= star - 1)
        {
            return 0;
        }

        return (int)Math.Round((Value - (star - 1)) * 100);
    }

    private Task SetRating(int stars)
    {
        return ValueChanged.InvokeAsync(stars);
    }
}
