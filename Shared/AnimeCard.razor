@using AnimeTracker.Data
@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager Navigation
@inject AnimeDataService DataService
@inject IJSRuntime JS

<div class="anime-card compact-card clickable-card @(SwipeStateClass) @(SwipeTargetClass)" role="button" tabindex="0"
     @ref="cardRef"
     @onclick="ViewDetails"
     @onkeydown="HandleKey"
     @onpointerdown="StartSwipe"
     @onpointermove="UpdateSwipe"
     @onpointerup="FinishSwipe"
     @onpointercancel="CancelSwipe"
     @onpointerdown:preventDefault="true"
     @onpointermove:preventDefault="true"
     style="@GetCardStyle()">
    <div class="swipe-overlay">@SwipeText</div>
    <img class="anime-card-thumb" src="@(string.IsNullOrWhiteSpace(Entry.ImageUrl) ? "https://images.unsplash.com/photo-1529484961088-8ca3cb593af1?auto=format&fit=crop&w=1200&q=80" : Entry.ImageUrl)" alt="@Entry.Title" />

    <div class="anime-card-content">
        <div class="anime-card-title-row">
            <div>
                <h3>@Entry.Title</h3>
                @if (!string.IsNullOrWhiteSpace(Entry.Genre))
                {
                    <small class="genre-label">@Entry.Genre</small>
                }
            </div>
            <span class="status-pill @Entry.Status.ToString().ToLower()">@Entry.StatusLabel</span>
        </div>

        <div class="rating-row">
            <div class="rating-stars">
                @for (var i = 1; i <= 5; i++)
                {
                    var fill = Math.Clamp((Entry.Rating - (i - 1)) * 100, 0, 100);
                    <span class="rating-star" style="--fill:@fill%">★</span>
                }
            </div>
            <span class="rating-label">@Entry.RatingLabel</span>
        </div>

        <p class="anime-card-description">@Entry.Description</p>
    </div>
</div>

@code {
    [Parameter] public AnimeEntry Entry { get; set; } = default!;
    [Parameter] public string FromTab { get; set; } = string.Empty;
    [Parameter] public EventCallback<AnimeEntry> OnEntryUpdated { get; set; }

    private ElementReference cardRef;
    private double dragStartX;
    private double dragOffset;
    private bool isPointerDown;
    private bool hasDragged;
    private bool ignoreClick;
    private bool isSwipedAway;
    private string swipeDirection = string.Empty;

    private string SwipeStateClass
        => isSwipedAway ? "swipe-away"
            : hasDragged ? (dragOffset > 0 ? "swipe-right" : "swipe-left")
            : string.Empty;

    private string SwipeTargetClass
        => FromTab == "Watch Later" && swipeDirection == "right" ? "swipe-target-watching"
            : FromTab == "Watching" && swipeDirection == "right" ? "swipe-target-finished"
            : FromTab == "Watching" && swipeDirection == "left" ? "swipe-target-watchlater"
            : string.Empty;

    private string SwipeText
    {
        get
        {
            if (!hasDragged)
            {
                return string.Empty;
            }

            if (FromTab == "Watch Later")
            {
                return dragOffset > 0 ? "Move to Watching →" : "Slide right to move";
            }

            if (FromTab == "Watching")
            {
                return dragOffset > 0 ? "Move to Finished →" : "← Move to Watch Later";
            }

            return string.Empty;
        }
    }

    private string GetCardStyle()
    {
        if (isSwipedAway)
        {
            var offset = dragOffset > 0 ? 420 : -420;
            return $"transform: translateX({offset}px); opacity: 0; transition: transform 0.25s ease, opacity 0.25s ease;";
        }

        if (hasDragged)
        {
            return $"transform: translateX({dragOffset}px);";
        }

        return string.Empty;
    }

    private async Task StartSwipe(PointerEventArgs args)
    {
        isPointerDown = true;
        dragStartX = args.ClientX;
        dragOffset = 0;
        hasDragged = false;
        ignoreClick = false;
        swipeDirection = string.Empty;

        try
        {
            await JS.InvokeVoidAsync("animeTracker.capturePointer", cardRef, args.PointerId);
        }
        catch
        {
            // ignore if pointer capture is unavailable
        }
    }

    private void UpdateSwipe(PointerEventArgs args)
    {
        if (!isPointerDown || isSwipedAway)
        {
            return;
        }

        dragOffset = args.ClientX - dragStartX;
        if (Math.Abs(dragOffset) > 10)
        {
            hasDragged = true;
            swipeDirection = dragOffset > 0 ? "right" : "left";
        }
    }

    private async Task FinishSwipe(PointerEventArgs args)
    {
        if (!isPointerDown || isSwipedAway)
        {
            return;
        }

        isPointerDown = false;
        await ReleasePointer(args.PointerId);

        if (Math.Abs(dragOffset) >= 80 && TryApplySwipeAction())
        {
            ignoreClick = true;
            isSwipedAway = true;
            StateHasChanged();
            await DataService.AddOrUpdateAsync(Entry);
            await Task.Delay(220);
            await OnEntryUpdated.InvokeAsync(Entry);
            return;
        }

        ResetSwipe();
    }

    private async Task CancelSwipe(PointerEventArgs args)
    {
        if (!isPointerDown || isSwipedAway)
        {
            return;
        }

        isPointerDown = false;
        await ReleasePointer(args.PointerId);

        if (hasDragged)
        {
            ignoreClick = true;
        }

        ResetSwipe();
    }

    private void ResetSwipe()
    {
        dragOffset = 0;
        hasDragged = false;
        swipeDirection = string.Empty;
    }

    private bool TryApplySwipeAction()
    {
        if (FromTab == "Watch Later" && swipeDirection == "right")
        {
            Entry.Status = AnimeStatus.Watching;
            if (Entry.StartDate == null)
            {
                Entry.StartDate = DateTime.Today;
            }

            return true;
        }

        if (FromTab == "Watching")
        {
            if (swipeDirection == "right")
            {
                Entry.Status = AnimeStatus.Finished;
                if (Entry.EndDate == null)
                {
                    Entry.EndDate = DateTime.Today;
                }

                return true;
            }

            if (swipeDirection == "left")
            {
                Entry.Status = AnimeStatus.WatchLater;
                Entry.EndDate = null;
                return true;
            }
        }

        return false;
    }

    private async Task ReleasePointer(long pointerId)
    {
        try
        {
            await JS.InvokeVoidAsync("animeTracker.releasePointer", cardRef, pointerId);
        }
        catch
        {
            // ignore if pointer release is unavailable
        }
    }

    private void ViewDetails()
    {
        if (ignoreClick || hasDragged)
        {
            ignoreClick = false;
            hasDragged = false;
            return;
        }

        var target = $"{Navigation.BaseUri}anime/{Entry.Id}";
        if (!string.IsNullOrWhiteSpace(FromTab))
        {
            target += $"?from={Uri.EscapeDataString(FromTab)}";
        }

        Navigation.NavigateTo(target);
    }

    private async Task HandleKey(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" || args.Key == " ")
        {
            ViewDetails();
        }

        await Task.CompletedTask;
    }
}
