@page "/storage"
@using AnimeTracker.Data
@inject AnimeDataService DataService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>CSV Storage</PageTitle>

<div class="page-header">
    <div>
        <p class="eyebrow">CSV backup</p>
        <h1>Export and import your list</h1>
        <p>Save a backup to your phone or upload an existing CSV file to restore your anime collection.</p>
    </div>
    <NavLink class="btn btn-secondary" href="@Navigation.BaseUri">Back</NavLink>
</div>

<div class="storage-panel">
    <div class="storage-card">
        <h2>Export CSV</h2>
        <p>Download or copy a CSV backup of your current anime data.</p>
        <button class="btn btn-primary" @onclick="ExportCsv">Download backup</button>
        <button class="btn btn-secondary" @onclick="CopyCsv">Copy backup</button>
    </div>
    <div class="storage-card">
        <h2>Import CSV</h2>
        <p>Choose a CSV file exported from AnimeTracker, or paste CSV text from your clipboard.</p>
        <InputFile OnChange="ImportCsv" accept=".csv" />
        <button class="btn btn-secondary" @onclick="PasteCsv">Paste CSV</button>
        <button class="btn btn-secondary" @onclick="ClearData">Clear all current data</button>
        @if (!string.IsNullOrEmpty(ImportStatus))
        {
            <div class="import-status">@ImportStatus</div>
        }
    </div>
</div>

@code {
    private string ImportStatus { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await DataService.InitializeAsync();
    }

    private async Task ExportCsv()
    {
        await DataService.ExportCsvAsync();
    }

    private async Task ClearData()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Clear all current anime data? This will reset the list and allow a fresh CSV import.");
        if (!confirmed)
        {
            return;
        }

        await DataService.ClearAllAsync();
        ImportStatus = "Current data cleared. You can now upload a new CSV file.";
    }

    private async Task CopyCsv()
    {
        var csv = await DataService.GetExportCsvTextAsync();
        var copied = await JSRuntime.InvokeAsync<bool>("animeTracker.copyTextToClipboard", csv);
        ImportStatus = copied ? "Current CSV copied to clipboard." : "Unable to copy CSV. Please allow clipboard access or use a compatible browser.";
    }

    private async Task PasteCsv()
    {
        var clipboardText = await JSRuntime.InvokeAsync<string?>("animeTracker.readTextFromClipboard");
        if (string.IsNullOrWhiteSpace(clipboardText))
        {
            ImportStatus = "No CSV text found in clipboard.";
            return;
        }

        await DataService.ImportCsvTextAsync(clipboardText);
        ImportStatus = "CSV pasted from clipboard and imported successfully.";
    }

    private async Task ImportCsv(InputFileChangeEventArgs args)
    {
        if (args.FileCount == 0)
        {
            return;
        }

        var file = args.File;
        await DataService.ImportCsvAsync(file);
        ImportStatus = $"Imported {file.Name} successfully.";
    }
}
