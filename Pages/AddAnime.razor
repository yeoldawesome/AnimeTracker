@page "/add"
@using AnimeTracker.Data
@inject AnimeDataService DataService
@inject NavigationManager Navigation

<PageTitle>Add Anime</PageTitle>

<div class="page-header">
    <div>
        <p class="eyebrow">New anime</p>
        <h1>Add a new title</h1>
        <p>Fill in the details and save your anime to the tracker.</p>
    </div>
    <NavLink class="btn btn-secondary" href="@Navigation.BaseUri">Back</NavLink>
</div>

<EditForm Model="NewAnime" OnValidSubmit="SaveAnime">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-grid">
        <div class="form-card">
            <label>Title</label>
            <InputText class="form-control" @bind-Value="NewAnime.Title" />

            <label>Description</label>
            <InputTextArea class="form-control" @bind-Value="NewAnime.Description" Rows="5" />

            <label>Found date</label>
            <InputDate class="form-control" @bind-Value="NewAnime.FoundDate" />

            <label>Start watching</label>
            <InputDate class="form-control" @bind-Value="NewAnime.StartDate" />

            <label>End watching</label>
            <InputDate class="form-control" @bind-Value="NewAnime.EndDate" />

            <label>Series link</label>
            <InputText class="form-control" @bind-Value="NewAnime.Link" />

            <label>Genre</label>
            <InputText class="form-control" @bind-Value="NewAnime.Genre" />

            <label>Image URL</label>
            <InputText class="form-control" @bind-Value="NewAnime.ImageUrl" />

            <label class="btn btn-secondary" for="add-image-file">Upload from camera roll</label>
            <InputFile id="add-image-file" style="display:none;" OnChange="UploadImage" accept="image/*" />

            @if (!string.IsNullOrWhiteSpace(NewAnime.ImageUrl))
            {
                <div class="image-preview">
                    <img src="@NewAnime.ImageUrl" alt="Selected anime image preview" />
                </div>
            }
        </div>

        <div class="form-card">
            <label>Rating</label>
            <StarRating Value="NewAnime.Rating" ValueChanged="OnRatingChanged" />
            <InputNumber class="form-control" @bind-Value="NewAnime.Rating" Min="0" Max="5" />
            <div class="rating-note">Tap stars or enter a number 0–5.</div>

            <label>Status</label>
            <InputSelect class="form-control" @bind-Value="NewAnime.Status">
                <option value="AnimeStatus.WatchLater">Watch Later</option>
                <option value="AnimeStatus.Watching">Watching</option>
                <option value="AnimeStatus.Finished">Finished</option>
            </InputSelect>

            <label>Language</label>
            <InputSelect class="form-control" @bind-Value="NewAnime.Language">
                <option value="WatchLanguage.SubOnly">Sub Only</option>
                <option value="WatchLanguage.DubAvailable">Dub Available</option>
            </InputSelect>

            <label>Seasons</label>
            <InputNumber class="form-control" @bind-Value="NewAnime.Seasons" Min="1" />

            <label>Episodes per season</label>
            <InputNumber class="form-control" @bind-Value="NewAnime.EpisodesPerSeason" Min="1" />

            <label>Episodes watched</label>
            <InputNumber class="form-control" @bind-Value="NewAnime.EpisodesWatched" Min="0" Max="999" />

            <label>Notes</label>
            <InputTextArea class="form-control" @bind-Value="NewAnime.Notes" Rows="4" />
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save anime</button>
        <button type="button" class="btn btn-secondary" @onclick="ResetForm">Reset</button>
    </div>
</EditForm>

@code {
    private AnimeEntry NewAnime { get; set; } = new AnimeEntry();

    protected override async Task OnInitializedAsync()
    {
        await DataService.InitializeAsync();
    }

    private Task OnRatingChanged(double value)
    {
        NewAnime.Rating = value;
        return Task.CompletedTask;
    }

    private async Task UploadImage(InputFileChangeEventArgs e)
    {
        var file = e.File;
        using var stream = file.OpenReadStream(maxAllowedSize: 5_000_000);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);
        var imageBytes = memoryStream.ToArray();
        NewAnime.ImageUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(imageBytes)}";
    }

    private async Task SaveAnime()
    {
        if (string.IsNullOrWhiteSpace(NewAnime.Title))
        {
            return;
        }

        if (NewAnime.FoundDate == null)
        {
            NewAnime.FoundDate = DateTime.Today;
        }

        if (NewAnime.EpisodesWatched > NewAnime.Seasons * NewAnime.EpisodesPerSeason)
        {
            NewAnime.EpisodesWatched = NewAnime.Seasons * NewAnime.EpisodesPerSeason;
        }

        if (NewAnime.Status == AnimeStatus.Watching && NewAnime.StartDate == null)
        {
            NewAnime.StartDate = DateTime.Today;
        }

        if (NewAnime.Status == AnimeStatus.Finished && NewAnime.EndDate == null)
        {
            NewAnime.EndDate = DateTime.Today;
        }

        await DataService.AddOrUpdateAsync(NewAnime);
        NewAnime = new AnimeEntry();
        Navigation.NavigateTo(Navigation.BaseUri);
    }

    private void ResetForm()
    {
        NewAnime = new AnimeEntry();
    }
}
