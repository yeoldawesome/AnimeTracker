@page "/watching"
@using AnimeTracker.Data

<PageTitle>Watching</PageTitle>

<div class="page-header">
    <div>
        <p class="eyebrow">Watching</p>
        <h1>Currently watching</h1>
        <p>Update your episode progress and move titles as you finish them.</p>
