@page "/anime/{AnimeId}"
@using AnimeTracker.Data
@inject AnimeDataService DataService
@inject NavigationManager Navigation

<PageTitle>Anime details</PageTitle>

@if (Entry is null)
{
    <div class="empty-state">
        <h2>Anime not found</h2>
        <p>This title may have been removed or the link is invalid.</p>
        <NavLink class="btn btn-primary" href="@Navigation.BaseUri">Back to home</NavLink>
    </div>
}
else
{
    <div class="page-header detail-header">
        <button type="button" class="btn btn-secondary" @onclick="Back">Back</button>
    </div>

    <EditForm Model="Entry" OnValidSubmit="SaveEntry">
        <div class="detail-card detail-full-card">
            <div class="detail-title-row">
                <div class="title-edit">
                    <InputText class="detail-title-input" @bind-Value="Entry.Title" @onblur="SaveEntry" />
                </div>
                <div class="pill-actions">
                    <InputSelect class="@($"pill-select status-pill {Entry.Status.ToString().ToLower()}")" @bind-Value="Entry.Status" @onchange="OnStatusChanged">
                        <option value="@AnimeStatus.WatchLater">Watch Later</option>
                        <option value="@AnimeStatus.Watching">Watching</option>
                        <option value="@AnimeStatus.Finished">Finished</option>
                    </InputSelect>
                    <InputSelect class="@($"pill-select language-pill {(Entry.Language == WatchLanguage.DubAvailable ? "dub" : "sub")}")" @bind-Value="Entry.Language" @onchange="SaveEntry">
                        <option value="@WatchLanguage.SubOnly">SUB</option>
                        <option value="@WatchLanguage.DubAvailable">DUB</option>
                    </InputSelect>
                </div>
            </div>

            <label>Description</label>
            <InputTextArea class="form-control" @bind-Value="Entry.Description" Rows="4" @onblur="SaveEntry" />

            <label>Genre</label>
            <InputText class="form-control" @bind-Value="Entry.Genre" @onblur="SaveEntry" />

            <label>Notes</label>
            <InputTextArea class="form-control" @bind-Value="Entry.Notes" Rows="3" @onblur="SaveEntry" />

            <div class="detail-row">
                <div>
                    <label>Rating</label>
                    <StarRating Value="Entry.Rating" ValueChanged="OnRatingChanged" />
                </div>
                <div>
                    <label>Found date</label>
                    <InputDate class="form-control" @bind-Value="Entry.FoundDate" @onblur="SaveEntry" />
                </div>
            </div>

            <div class="detail-row">
                <div>
                    <label>Start date</label>
                    <InputDate class="form-control" @bind-Value="Entry.StartDate" @onblur="SaveEntry" />
                </div>
                <div>
                    <label>End date</label>
                    <InputDate class="form-control" @bind-Value="Entry.EndDate" @onblur="SaveEntry" />
                </div>
            </div>

            <label>Link</label>
            <InputText class="form-control" @bind-Value="Entry.Link" @onblur="SaveEntry" />

            <div class="detail-row">
                <div>
                    <label>Seasons</label>
                    <InputNumber class="form-control" @bind-Value="Entry.Seasons" @onchange="SaveEntry" Min="1" />
                </div>
                <div>
                    <label>Episodes / season</label>
                    <InputNumber class="form-control" @bind-Value="Entry.EpisodesPerSeason" @onchange="SaveEntry" Min="1" />
                </div>
                <div>
                    <label>Episodes watched</label>
                    <InputNumber class="form-control" @bind-Value="Entry.EpisodesWatched" @onchange="SaveEntry" Min="0" />
                </div>
            </div>

            <label>Image URL</label>
            <InputText class="form-control" @bind-Value="Entry.ImageUrl" @onblur="SaveEntry" />

            <label>Image preview</label>
            <div class="image-preview">
                <img src="@(string.IsNullOrWhiteSpace(Entry.ImageUrl) ? "https://images.unsplash.com/photo-1529484961088-8ca3cb593af1?auto=format&fit=crop&w=1200&q=80" : Entry.ImageUrl)" alt="@Entry.Title" />
            </div>

            <div class="detail-actions detail-actions-single">
                <button type="button" class="btn btn-danger btn-outline" @onclick="DeleteEntry">Delete</button>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter] public string AnimeId { get; set; } = string.Empty;
    private AnimeEntry? Entry { get; set; }
    private string PreviousTab { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await DataService.InitializeAsync();
        Entry = DataService.GetById(AnimeId);
        PreviousTab = GetPreviousTab();
    }

    private string GetPreviousTab()
    {
        var uri = new Uri(Navigation.Uri);
        var query = uri.Query?.TrimStart('?');
        if (string.IsNullOrEmpty(query))
        {
            return string.Empty;
        }

        var parts = query.Split('&', StringSplitOptions.RemoveEmptyEntries);
        foreach (var part in parts)
        {
            var pair = part.Split('=', 2);
            if (pair.Length == 2 && pair[0] == "from")
            {
                return Uri.UnescapeDataString(pair[1].Replace('+', ' '));
            }
        }

        return string.Empty;
    }

    private async Task Back()
    {
        await SaveEntry();

        var target = Entry?.Status switch
        {
            AnimeStatus.WatchLater => "/watch-later",
            AnimeStatus.Watching => "/watching",
            AnimeStatus.Finished => "/finished",
            _ => Navigation.BaseUri
        };

        Navigation.NavigateTo(target);
    }

    private async Task SaveEntry()
    {
        if (Entry is null)
        {
            return;
        }

        if (Entry.EpisodesWatched > Entry.TotalEpisodes)
        {
            Entry.EpisodesWatched = Entry.TotalEpisodes;
        }

        ApplyStatusDates(Entry);
        await DataService.AddOrUpdateAsync(Entry);
    }

    private static void ApplyStatusDates(AnimeEntry entry)
    {
        if ((entry.Status == AnimeStatus.Watching || entry.Status == AnimeStatus.Finished) && entry.StartDate == null)
        {
            entry.StartDate = DateTime.Today;
        }

        if (entry.Status == AnimeStatus.Finished && entry.EndDate == null)
        {
            entry.EndDate = DateTime.Today;
        }
    }

    private async Task OnStatusChanged(ChangeEventArgs args)
    {
        if (Entry is null)
        {
            return;
        }

        if (args?.Value is string value && Enum.TryParse<AnimeStatus>(value, out var status))
        {
            Entry.Status = status;
            ApplyStatusDates(Entry);
            await SaveEntry();
        }
    }

    private async Task OnRatingChanged(double value)
    {
        if (Entry is null)
        {
            return;
        }

        Entry.Rating = value;
        await SaveEntry();
    }

    private async Task DeleteEntry()
    {
        if (Entry is null)
        {
            return;
        }

        await DataService.RemoveAsync(Entry.Id);
        Navigation.NavigateTo(Navigation.BaseUri);
    }
}
